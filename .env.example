# ─────────────────────────────────────────────
# WSO2 Docs MCP Server — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in the values

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://wso2mcp:wso2mcp@localhost:5432/wso2docs

# ── Embedding Provider ────────────────────────
# Choose one: openai | gemini | voyage
EMBEDDING_PROVIDER=openai

# OpenAI (EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=sk-...
# Models: text-embedding-3-small (1536), text-embedding-3-large (3072), text-embedding-ada-002 (1536)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Google Gemini (EMBEDDING_PROVIDER=gemini)
GEMINI_API_KEY=AIza...
# Models: text-embedding-004 (768 dims)
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Voyage AI (EMBEDDING_PROVIDER=voyage)
VOYAGE_API_KEY=pa-...
# Models: voyage-3 (1024), voyage-3-lite (512), voyage-code-3 (1024)
VOYAGE_EMBEDDING_MODEL=voyage-3

# Set to match the model output dimensions above
# OpenAI small=1536 | Gemini 004=768 | Voyage-3=1024
EMBEDDING_DIMENSIONS=1536

# ── MCP Server ────────────────────────────────
MCP_SERVER_NAME=wso2-docs-mcp
MCP_SERVER_VERSION=1.0.0

# ── Crawler ───────────────────────────────────
# Concurrent HTTP requests during crawl
CRAWL_CONCURRENCY=5

# ── Chunker ───────────────────────────────────
# Approximate token count per chunk (1 token ≈ 4 chars)
CHUNK_SIZE=800
# Overlap in tokens between consecutive chunks
CHUNK_OVERLAP=100

# ── Cache ─────────────────────────────────────
# In-memory query cache TTL in seconds
CACHE_TTL_SECONDS=3600
# Default number of results returned by search tools
TOP_K_RESULTS=10
